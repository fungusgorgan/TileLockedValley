    <RootNamespace>TileLocked</RootNamespace>
    <TargetFramework>net6.0</TargetFramework>
    <EnableHarmony>true</EnableHarmony>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <SMAPIDependency Include="Pathoschild.ContentPatcher" />
  </ItemGroup>

  <ItemGroup>
    <SMAPIDependency Include="spacechase0.GenericModConfigMenu" />
  </ItemGroup>
  
  <ItemGroup>
    <ContentPacks Include="[Content Pack] Tile-Locked Valley" Version="1.0.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" />
  </ItemGroup>

</Project>
